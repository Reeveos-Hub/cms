# ReeveOS CMS Environment Variables
# Copy to .env and fill in values

# MongoDB connection - uses SEPARATE database from main app
DATABASE_URI=mongodb://127.0.0.1:27017/reeveos_cms

# Payload secret - generate a long random string
PAYLOAD_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Server URL
NEXT_PUBLIC_SERVER_URL=https://portal.rezvo.app

# Port
PORT=3000
